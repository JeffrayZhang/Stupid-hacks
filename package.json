{
  "name": "prmon-go",
  "version": "1.0.0",
  "private": true,
  "description": "PR-mon GO: Gotta Merge 'Em All",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && node --watch index.js",
    "dev:server:env": "cd server && node --watch --env-file=../.env index.js",
    "dev:client": "cd battle-prototype/client && npx vite --port 3000 --host",
    "dev:mock": "cd battle-prototype/client && npx vite --port 3000 --host",
    "start": "cd battle-prototype/client && npx vite --port 3000 --host",
    "install:all": "npm install && cd server && npm install && cd ../battle-prototype/client && npm install",
    "postinstall": "cd battle-prototype/client && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
