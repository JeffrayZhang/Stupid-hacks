# GitHub token (or use `gh auth token` — server auto-detects)
GITHUB_TOKEN=

# Target repo with open PRs
GITHUB_OWNER=JeffrayZhang
GITHUB_REPO=prmon-test-arena

# API URL for the client (set this to enable real API mode)
# When running with `npm run dev`, the Vite proxy handles this automatically
# so you usually don't need to set this.
# VITE_API_URL=http://localhost:3001
